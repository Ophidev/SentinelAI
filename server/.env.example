PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/sentinelai
JWT_SECRET=change_this_to_a_long_random_string

# Optional: if unset, AI explanations fall back to a rule-based template
# (see server/src/ai/index.js) — the app works fully without this.
GEMINI_API_KEY=

# Optional: a fine-grained GitHub personal access token with
# "Public Repositories (read-only)" access only. Without this, code scans
# still work but are limited to GitHub's unauthenticated rate limit
# (60 requests/hour) — see server/src/codeScanner/githubClient.js.
GITHUB_TOKEN=
